  "description": "An Obsidian plugin with a floating toolbar for per-note layout, heading colors, and table formatting.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
