    "plugin",
    "layout",
    "floating-toolbar",
    "table-formatting"
  ],
  "author": "HuYbio9566",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.10",
    "builtin-modules": "^3.3.0",
